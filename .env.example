# deckhandAI — environment variables
# Copy this file to .env.local and fill in your values.

# ── Required ─────────────────────────────────────────────────────────────────

# GitHub personal access token with `repo` scope (read + write the data repo)
GITHUB_TOKEN=ghp_your_token_here

# Private GitHub repo that stores your data files (owner/repo format)
# This repo should contain data/jobs.json and data/config.json
GITHUB_DATA_REPO=your-username/your-data-repo

# Password to log in to the deckhandAI dashboard
APP_PASSWORD=change-me

# Random 32+ character string for signing session cookies
# Generate one: openssl rand -base64 32
COOKIE_SECRET=change-me-to-a-random-32-char-string

# ── Optional ─────────────────────────────────────────────────────────────────

# Branch to read/write in the data repo (default: main)
# GITHUB_DATA_BRANCH=main

# AI generation (BYOM — bring your own model)
# AI_PROVIDER=anthropic       # anthropic | openai | ollama | custom
# AI_BASE_URL=                # Ollama or custom OpenAI-compatible endpoint
# AI_API_KEY=                 # Not needed for Ollama

# Set to "true" to enable read-only demo mode — bypasses auth, loads sample data
# DEMO_MODE=false
